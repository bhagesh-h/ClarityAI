{
  "manifest_version": 3,
  "name": "Clarity AI",
  "version": "0.0.1",
  "description": "Summarize, Explain, Reference and Professional Reply generator.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icon.svg",
    "32": "icon.svg",
    "48": "icon.svg",
    "128": "icon.svg"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": "icon.svg"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content-loader.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content.css",
        "content.js",
        "assets/*",
        "icon.svg",
        "logo.svg"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}